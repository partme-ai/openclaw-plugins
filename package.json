{
  "name": "openclaw-plugins",
  "version": "1.0.0",
  "private": true,
  "description": "30+ Enterprise Plugins for OpenClaw. One Standard. Built for production. Not for demos.",
  "repository": {
    "type": "git",
    "url": "https://github.com/partme-ai/openclaw-plugins.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "new-plugin": "node scripts/new-plugin.mjs",
    "check-plugin-structure": "node scripts/check-plugin-structure.mjs",
    "check-plugin-structure:strict-base": "node scripts/check-plugin-structure.mjs --strict-base",
    "check-plugin-structure:strict-new": "node scripts/check-plugin-structure.mjs --strict-new",
    "check-plugin-structure:strict": "node scripts/check-plugin-structure.mjs --strict-base",
    "publish-changed": "node scripts/publish-changed.mjs",
    "sync-message-sdk-deps": "node scripts/sync-message-sdk-deps.mjs",
    "e2e": "node scripts/e2e/run-e2e.mjs",
    "e2e:host": "OPENCLAW_E2E_HOST_GATEWAY=1 node scripts/e2e/run-e2e.mjs",
    "test:unit": "node scripts/test-plugins.mjs --unit-only",
    "test:e2e": "node scripts/test-plugins.mjs --e2e-only",
    "test:plugins": "node scripts/test-plugins.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "openclaw": "2026.5.18",
    "playwright": "1.52.0"
  }
}
