{
  "name": "@partme.ai/weixin",
  "version": "2026.5.20",
  "description": "OpenClaw Weixin channel",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Tencent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "README.zh_CN.md",
    "CHANGELOG.md",
    "CHANGELOG.zh_CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "qrcode-terminal": "0.12.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.0",
    "openclaw": "^2026.5.18",
    "silk-wasm": "^3.7.1",
    "tsup": "^8.2.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "openclaw-weixin",
      "label": "openclaw-weixin",
      "selectionLabel": "openclaw-weixin",
      "docsPath": "/channels/openclaw-weixin",
      "docsLabel": "openclaw-weixin",
      "blurb": "Weixin channel",
      "order": 75
    },
    "install": {
      "npmSpec": "@tencent-weixin/openclaw-weixin",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    }
  },
  "ilink_appid": "bot",
  "repository": {
    "type": "git",
    "url": "https://github.com/partme-ai/openclaw-plugins.git",
    "directory": "extensions/wechat"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.12"
  }
}
