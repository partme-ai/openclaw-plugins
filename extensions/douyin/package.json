{
  "name": "@partme.ai/openclaw-douyin",
  "version": "2026.5.20",
  "description": "OpenClaw 抖音开放平台渠道与运营工具 — 公域 Agent-First 智能运营",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "douyin",
    "channel",
    "公域",
    "智能运营"
  ],
  "author": "PartMe",
  "license": "MIT",
  "dependencies": {
    "@partme.ai/openclaw-message-sdk": "workspace:^2026.5.25"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "tsconfig.json",
    "tsup.config.ts",
    "vitest.config.ts",
    ".gitignore"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.4.12"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": ">=2026.4.12",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/partme-ai/openclaw-plugins.git",
    "directory": "extensions/douyin"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "douyin",
      "label": "抖音",
      "blurb": "抖音开放平台 Webhook 渠道与运营工具"
    }
  }
}
