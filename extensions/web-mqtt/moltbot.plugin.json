{
  "id": "web-mqtt",
  "name": "web-mqtt",
  "version": "0.1.9",
  "description": "Enterprise MQTT over WebSocket channel plugin for OpenClaw",
  "main": "dist/index.js",
  "channels": [
    "mqtt-ws"
  ],
  "commands": [],
  "skills": [],
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "channels": {
        "type": "object",
        "properties": {
          "mqtt-ws": {
            "type": "object",
            "properties": {
              "port": {
                "type": "number",
                "default": 15675
              },
              "path": {
                "type": "string",
                "default": "/ws"
              },
              "host": {
                "type": "string",
                "default": "0.0.0.0"
              },
              "maxConnections": {
                "type": "number",
                "default": 5000
              },
              "topicPrefix": {
                "type": "string",
                "default": "openclaw/"
              },
              "subscribeTopics": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "topicBindings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "topicPattern": {
                      "type": "string"
                    },
                    "agentId": {
                      "type": "string"
                    },
                    "accountId": {
                      "type": "string"
                    },
                    "replyTopic": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "topicPattern",
                    "agentId"
                  ]
                },
                "default": []
              },
              "payload": {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "default": "jsonTextOrPlain"
                  }
                }
              },
              "auth": {
                "type": "object",
                "properties": {
                  "required": {
                    "type": "boolean",
                    "default": true
                  },
                  "allowAnonymous": {
                    "type": "boolean",
                    "default": false
                  },
                  "users": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "username": {
                          "type": "string"
                        },
                        "password": {
                          "type": "string"
                        },
                        "passwordHash": {
                          "type": "string"
                        },
                        "hashAlgorithm": {
                          "type": "string"
                        },
                        "publishAllow": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "subscribeAllow": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "aclRules": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "action": {
                                "type": "string"
                              },
                              "topicPattern": {
                                "type": "string"
                              },
                              "effect": {
                                "type": "string"
                              },
                              "accountId": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    },
                    "default": []
                  }
                }
              },
              "tls": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "default": false
                  },
                  "keyFile": {
                    "type": "string"
                  },
                  "certFile": {
                    "type": "string"
                  },
                  "caFile": {
                    "type": "string"
                  },
                  "minVersion": {
                    "type": "string",
                    "default": "TLSv1.2"
                  },
                  "requestCert": {
                    "type": "boolean",
                    "default": false
                  },
                  "rejectUnauthorized": {
                    "type": "boolean",
                    "default": false
                  }
                }
              },
              "ws": {
                "type": "object",
                "properties": {
                  "compress": {
                    "type": "boolean",
                    "default": true
                  },
                  "idleTimeoutMs": {
                    "type": "number",
                    "default": 60000
                  },
                  "maxFrameSize": {
                    "type": "number",
                    "default": 262144
                  }
                }
              },
              "limits": {
                "type": "object",
                "properties": {
                  "maxPayloadBytes": {
                    "type": "number",
                    "default": 1048576
                  },
                  "maxSubscriptionsPerClient": {
                    "type": "number",
                    "default": 200
                  }
                }
              },
              "proxyProtocol": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "channels.mqtt-ws.port": {
      "label": "WebSocket Port",
      "placeholder": "15675"
    },
    "channels.mqtt-ws.path": {
      "label": "WebSocket Path",
      "placeholder": "/ws"
    },
    "channels.mqtt-ws.maxConnections": {
      "label": "Max Connections",
      "placeholder": "5000"
    },
    "channels.mqtt-ws.topicPrefix": {
      "label": "Topic Prefix",
      "placeholder": "openclaw/"
    },
    "channels.mqtt-ws.auth.required": {
      "label": "Require Authentication",
      "type": "toggle"
    },
    "channels.mqtt-ws.tls.enabled": {
      "label": "Enable WSS (TLS)",
      "type": "toggle"
    }
  },
  "capabilities": {
    "protocolBridge": true,
    "websocket": true
  },
  "channelConfigs": {
    "mqtt-ws": {
      "label": "openclaw-web-mqtt",
      "description": "Enterprise MQTT over WebSocket channel plugin for OpenClaw",
      "schema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {}
      }
    }
  }
}
