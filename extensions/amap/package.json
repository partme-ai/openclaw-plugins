{
  "name": "@partme.ai/openclaw-amap",
  "version": "2026.5.20",
  "type": "module",
  "description": "高德开放平台渠道与运营工具 — 公域 Agent-First 智能运营",
  "license": "MIT",
  "dependencies": {
    "@partme.ai/openclaw-message-sdk": "workspace:*"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "clawdbot.plugin.json",
    "moltbot.plugin.json",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "tsconfig.json",
    "tsup.config.ts",
    "vitest.config.ts",
    ".gitignore"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/partme-ai/openclaw-plugins.git",
    "directory": "extensions/amap"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "amap",
    "高德",
    "poi",
    "location"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.12"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": ">=2026.4.12",
    "tsup": "^8.2.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "amap",
      "label": "高德地图（Amap）",
      "blurb": "高德开放平台渠道与运营工具"
    }
  }
}
