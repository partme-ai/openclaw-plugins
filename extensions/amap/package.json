{
  "name": "@partme.ai/openclaw-amap",
  "version": "0.1.0",
  "type": "module",
  "description": "高德开放平台渠道与运营工具 — 公域 Agent-First 智能运营",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/partme-ai/openclaw-plugins.git",
    "directory": "extensions/amap"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "amap",
    "高德",
    "poi",
    "location"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.12"
  },
  "devDependencies": {
    "tsup": "^8.2.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
