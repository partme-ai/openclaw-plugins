{
  "name": "@partme.ai/wecom-ics",
  "version": "2026.3.24-beta",
  "type": "module",
  "description": "OpenClaw WeCom CS (WeChat Work) intelligent bot channel plugin",
  "main": "index.ts",
  "files": [
    "index.ts",
    "src/",
    "assets/",
    "changelog/",
    "skills/",
    "openclaw.plugin.json",
    "clawdbot.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wecom-cs",
      "label": "WeCom CS",
      "selectionLabel": "WeCom CS (plugin)",
      "detailLabel": "WeCom CS Bot",
      "docsPath": "/channels/wecom-cs",
      "docsLabel": "wecom-cs",
      "blurb": "Enterprise WeCom intelligent bot (API mode) via encrypted webhooks + passive replies.",
      "aliases": [
        "wechatwork",
        "wework",
        "qywx",
        "企微",
        "企业微信"
      ],
      "order": 85
    },
    "install": {
      "npmSpec": "@mocrane/wecom-cs",
      "localPath": "extensions/wecom-cs",
      "defaultChoice": "npm"
    }
  },
  "dependencies": {
    "@wecom/aibot-node-sdk": "^1.0.2",
    "fast-xml-parser": "5.3.4",
    "file-type": "^18.7.0",
    "undici": "^7.20.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.24"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "clawdbot": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wecom-cs",
      "label": "WeCom CS",
      "selectionLabel": "WeCom CS (plugin)",
      "detailLabel": "WeCom CS Bot",
      "docsPath": "/channels/wecom-cs",
      "docsLabel": "wecom-cs",
      "blurb": "Enterprise WeCom intelligent bot (API mode) via encrypted webhooks + passive replies.",
      "aliases": [
        "wechatwork",
        "wework",
        "qywx",
        "企微",
        "企业微信"
      ],
      "order": 85
    },
    "install": {
      "npmSpec": "@mocrane/wecom-cs",
      "localPath": "extensions/wecom-cs",
      "defaultChoice": "npm"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/partme-ai/openclaw-plugins.git",
    "directory": "extensions/wecom-ics"
  },
  "license": "Apache-2.0",
  "keywords": [
    "openclaw",
    "openclaw-plugin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  }
}
