{
  "name": "@partme.ai/openclaw-message-sdk",
  "version": "2026.5.20",
  "type": "module",
  "description": "统一消息格式 SDK — 所有 openclaw-plugins 渠道插件互通的消息结构定义",
  "license": "MIT",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "index.ts",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/partme-ai/openclaw-plugins.git",
    "directory": "extensions/message-sdk"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "message",
    "sdk",
    "unified-message"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.2.0",
    "typescript": "^5.7.0"
  }
}
