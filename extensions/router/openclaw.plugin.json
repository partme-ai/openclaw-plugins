{
  "id": "router",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "rules": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "match": {
              "type": "object",
              "properties": {
                "channels": { "type": "array", "items": { "type": "string" } },
                "direction": { "type": "string", "enum": ["inbound", "outbound", "both"] }
              }
            },
            "actions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["forward", "reply-via"] },
                  "target": { "type": "string" },
                  "topic": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "knowledge": {
        "type": "object",
        "properties": {
          "autoInject": { "type": "boolean", "default": false },
          "maxResults": { "type": "number", "default": 5 }
        }
      },
      "memory": {
        "type": "object",
        "properties": {
          "autoInject": { "type": "boolean", "default": false },
          "maxResults": { "type": "number", "default": 5 }
        }
      },
      "audit": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "logToConsole": { "type": "boolean", "default": false }
        }
      }
    }
  }
}
