{
  "name": "@partme.ai/redis-stream",
  "version": "2026.5.18",
  "description": "Redis Pub/Sub channel + Stream consumer group integration for OpenClaw.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "redis",
    "stream",
    "channel"
  ],
  "author": "PartMe",
  "license": "MIT",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "README_CN.md"
  ],
  "dependencies": {
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "redis-stream",
      "label": "Redis Stream",
      "blurb": "Redis Pub/Sub channel + Stream consumer group integration for OpenClaw."
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/partme-ai/openclaw-plugins.git",
    "directory": "extensions/redis-stream"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
