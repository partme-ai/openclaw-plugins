{
  "id": "openclaw-redis-stream",
  "version": "2026.5.20",
  "description": "Redis Pub/Sub channel + Stream consumer group integration for OpenClaw.",
  "main": "dist/index.js",
  "channels": ["redis-stream"],
  "activation": {
    "onStartup": true,
    "onChannels": ["redis-stream"]
  },
  "contracts": {
    "tools": []
  },
  "channelConfigs": {
    "redis-stream": {
      "label": "Redis Stream",
      "description": "Redis Pub/Sub channel + Stream consumer group integration for OpenClaw.",
      "schema": {
    "type": "object",
    "description": "Redis channel configuration for openclaw.json -> channels.redis-stream",
    "additionalProperties": true,
    "properties": {
      "url": {
        "type": "string",
        "description": "Redis connection URL (e.g. redis://localhost:6379)"
      },
      "channelMode": {
        "type": "string",
        "enum": ["pubsub", "stream"],
        "default": "pubsub",
        "description": "Inbound mode: pubsub (Redis Pub/Sub channels) or stream (Redis Stream consumer group)"
      },
      "defaultAgentId": {
        "type": "string",
        "default": "",
        "description": "Fallback agent ID when no channel binding or standard format matches. Empty = skip unroutable messages."
      },
      "subscribeChannels": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "Redis channels/patterns to subscribe (supports * wildcard). Empty = accept all."
      },
      "channelBindings": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "channelPattern": { "type": "string", "description": "Channel pattern (supports * wildcard)" },
            "agentId": { "type": "string", "description": "Target agent ID" },
            "accountId": { "type": "string", "description": "Account ID (default: \"default\")" },
            "replyChannel": { "type": "string", "description": "Reply channel override" }
          },
          "required": ["channelPattern", "agentId"]
        },
        "default": [],
        "description": "Explicit channel -> agent bindings (priority over standard format)"
      },
      "stream": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "inboundKey": { "type": "string", "default": "openclaw:inbound" },
          "outboundKey": { "type": "string", "default": "openclaw:outbound" },
          "consumerGroup": { "type": "string", "default": "openclaw-group" },
          "consumerName": { "type": "string", "default": "openclaw-consumer-1" },
          "blockMs": { "type": "number", "default": 5000 },
          "count": { "type": "number", "default": 10 },
          "createGroup": { "type": "boolean", "default": true }
        },
        "default": {
          "inboundKey": "openclaw:inbound",
          "outboundKey": "openclaw:outbound",
          "consumerGroup": "openclaw-group",
          "consumerName": "openclaw-consumer-1",
          "blockMs": 5000,
          "count": 10,
          "createGroup": true
        }
      },
      "payload": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["plain", "jsonTextOrPlain"],
            "default": "jsonTextOrPlain",
            "description": "Payload parsing mode"
          }
        },
        "default": { "mode": "jsonTextOrPlain" }
      },
      "fieldMapping": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "textField": { "type": "string", "default": "text" },
          "agentIdField": { "type": "string", "default": "agentId" },
          "peerIdField": { "type": "string", "default": "peerId" },
          "accountIdField": { "type": "string", "default": "accountId" },
          "replyStreamField": { "type": "string", "default": "replyStream" }
        },
        "default": {
          "textField": "text",
          "agentIdField": "agentId",
          "peerIdField": "peerId",
          "accountIdField": "accountId",
          "replyStreamField": "replyStream"
        }
      },
      "connection": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "reconnectMs": { "type": "number", "default": 3000 },
          "maxRetries": { "type": "number", "default": 10 }
        },
        "default": {
          "reconnectMs": 3000,
          "maxRetries": 10
        }
      }
    },
    "required": ["url"]
  }
      }
    },
    "configSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "description": "Redis Stream channel plugin configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the Redis Stream channel"
        },
        "redisUrl": {
          "type": "string",
          "format": "uri",
          "default": "redis://localhost:6379",
          "description": "Redis connection URL"
        },
        "channelMode": {
          "type": "string",
          "enum": ["pubsub", "stream"],
          "default": "pubsub",
          "description": "Inbound mode: pubsub or stream"
        },
        "defaultAgentId": {
          "type": "string",
          "default": "",
          "description": "Fallback agent ID when no route matches"
        },
        "channels": {
          "type": "array",
          "default": [],
          "description": "Channel configurations",
          "items": {
            "type": "object",
            "properties": {
              "channel": { "type": "string", "description": "Channel name/pattern" },
              "agentId": { "type": "string", "description": "Target agent ID" },
              "accountId": { "type": "string", "default": "default", "description": "Account ID" },
              "replyChannel": { "type": "string", "description": "Reply channel override" }
            },
            "required": ["channel", "agentId"]
          }
        },
        "payloadMode": {
          "type": "string",
          "enum": ["plainText", "jsonOnly", "jsonTextOrPlain"],
          "default": "jsonTextOrPlain",
          "description": "Message payload parsing mode"
        },
        "subscribeChannels": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Channels to subscribe (supports * wildcard)"
        },
        "stream": {
          "type": "object",
          "properties": {
            "inboundKey": { "type": "string", "default": "openclaw:inbound" },
            "outboundKey": { "type": "string", "default": "openclaw:outbound" },
            "consumerGroup": { "type": "string", "default": "openclaw-group" },
            "consumerName": { "type": "string", "default": "openclaw-consumer-1" },
            "blockMs": { "type": "number", "default": 5000 },
            "count": { "type": "number", "default": 10 },
            "createGroup": { "type": "boolean", "default": true }
          }
        },
        "fieldMapping": {
          "type": "object",
          "properties": {
            "textField": { "type": "string", "default": "text" },
            "agentIdField": { "type": "string", "default": "agentId" },
            "peerIdField": { "type": "string", "default": "peerId" },
            "accountIdField": { "type": "string", "default": "accountId" },
            "replyStreamField": { "type": "string", "default": "replyStream" }
          }
        },
        "connection": {
          "type": "object",
          "properties": {
            "reconnectMs": { "type": "number", "default": 3000 },
            "maxRetries": { "type": "number", "default": 10 }
          }
        }
      }
    }
  }
