{
  "id": "mqtt",
  "name": "openclaw-mqtt",
  "version": "0.1.13",
  "description": "MQTT 3.1.1/5.0 protocol bridge for OpenClaw - IoT device integration",
  "main": "dist/index.js",
  "channels": [
    "mqtt"
  ],
  "commands": [],
  "skills": [],
  "configSchema": {
    "type": "object",
    "properties": {
      "port": {
        "type": "number",
        "default": 1883,
        "description": "MQTT TCP listener port"
      },
      "tlsPort": {
        "type": "number",
        "default": 8883,
        "description": "MQTT TLS listener port (0 to disable)"
      },
      "tls": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable TLS for MQTT connections"
          },
          "certFile": {
            "type": "string",
            "description": "Path to TLS certificate file"
          },
          "keyFile": {
            "type": "string",
            "description": "Path to TLS key file"
          }
        }
      },
      "maxConnections": {
        "type": "number",
        "default": 10000,
        "description": "Maximum concurrent MQTT connections"
      },
      "qos": {
        "type": "object",
        "properties": {
          "maxQos": {
            "type": "number",
            "enum": [
              0,
              1,
              2
            ],
            "default": 1,
            "description": "Maximum QoS level supported"
          }
        }
      },
      "topicPrefix": {
        "type": "string",
        "default": "openclaw/",
        "description": "Topic prefix for agent message routing"
      },
      "auth": {
        "type": "object",
        "properties": {
          "required": {
            "type": "boolean",
            "default": true,
            "description": "Require MQTT client authentication"
          }
        }
      }
    }
  },
  "uiHints": {
    "port": {
      "label": "MQTT Port",
      "placeholder": "1883"
    },
    "tlsPort": {
      "label": "MQTT TLS Port",
      "placeholder": "8883"
    },
    "tls.enabled": {
      "label": "Enable TLS",
      "type": "toggle"
    },
    "tls.certFile": {
      "label": "TLS Certificate",
      "type": "file"
    },
    "tls.keyFile": {
      "label": "TLS Key",
      "type": "file"
    },
    "maxConnections": {
      "label": "Max Connections",
      "placeholder": "10000"
    },
    "qos.maxQos": {
      "label": "Max QoS Level",
      "type": "select"
    },
    "topicPrefix": {
      "label": "Topic Prefix",
      "placeholder": "openclaw/"
    },
    "auth.required": {
      "label": "Require Authentication",
      "type": "toggle"
    }
  },
  "capabilities": {
    "protocolBridge": true,
    "iot": true
  }
}