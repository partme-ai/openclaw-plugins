{
  "id": "wecom-kf",
  "name": "@partme.ai/wecom-kf",
  "description": "企业微信微信客服插件 — KF 消息收发 + 转人工 + 接待管理 + 知识库 RAG + 对话状态流 + ICS REST API",
  "main": "dist/index.js",
  "channels": [
    "wecom-kf"
  ],
  "commands": [
    "kf-status"
  ],
  "skills": [
    "./skills"
  ],
  "contracts": {
    "tools": ["wecom_kf_mcp", "wecom_kf_servicer_list", "wecom_kf_account_list", "wecom_kf_account_link", "wecom_kf_session_status", "wecom_kf_session_transfer"]
  },
  "capabilities": {
    "humanTransfer": true,
    "satisfactionSurvey": true,
    "sessionManagement": true
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "corpId": {
        "type": "string",
        "description": "企业微信 Corp ID"
      },
      "corpSecret": {
        "type": "string",
        "description": "企业微信客服应用 Secret"
      },
      "token": {
        "type": "string",
        "description": "回调 Token（用于消息签名验证）"
      },
      "encodingAESKey": {
        "type": "string",
        "description": "回调 EncodingAESKey（用于消息加解密）"
      },
      "session": {
        "type": "object",
        "properties": {
          "dmScope": {
            "type": "string",
            "enum": [
              "per-peer",
              "per-channel-peer",
              "per-account-channel-peer"
            ],
            "default": "per-account-channel-peer",
            "description": "Session isolation scope (recommended: per-account-channel-peer)"
          },
          "idleResetMinutes": {
            "type": "number",
            "default": 2880,
            "description": "Idle session reset time in minutes (default: 48h)"
          }
        }
      },
      "eventMessages": {
        "type": "object",
        "properties": {
          "welcome": {
            "type": "string",
            "default": "您好，我是 AI 智能客服，请问有什么可以帮您？",
            "description": "Session welcome message"
          },
          "ending": {
            "type": "string",
            "default": "感谢您的咨询，祝您生活愉快！",
            "description": "Session ending message"
          },
          "satisfaction": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Enable satisfaction survey"
              },
              "prompt": {
                "type": "string",
                "default": "请对本次服务进行评价",
                "description": "Satisfaction survey prompt"
              }
            }
          }
        }
      },
      "humanTransfer": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable human agent transfer capability"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "转人工",
              "人工客服",
              "人工"
            ],
            "description": "Keywords that trigger human transfer"
          }
        }
      }
    }
  },
  "uiHints": {
    "corpId": {
      "label": "Corp ID",
      "placeholder": "ww..."
    },
    "corpSecret": {
      "label": "Corp Secret",
      "type": "password"
    },
    "token": {
      "label": "Callback Token",
      "type": "password"
    },
    "encodingAESKey": {
      "label": "Encoding AES Key",
      "type": "password"
    },
    "session.dmScope": {
      "label": "Session Scope",
      "type": "select"
    },
    "session.idleResetMinutes": {
      "label": "Idle Reset (minutes)",
      "placeholder": "2880"
    },
    "eventMessages.welcome": {
      "label": "Welcome Message",
      "type": "textarea"
    },
    "eventMessages.ending": {
      "label": "Ending Message",
      "type": "textarea"
    },
    "eventMessages.satisfaction.enabled": {
      "label": "Enable Satisfaction Survey",
      "type": "toggle"
    },
    "eventMessages.satisfaction.prompt": {
      "label": "Survey Prompt"
    },
    "humanTransfer.enabled": {
      "label": "Enable Human Transfer",
      "type": "toggle"
    },
    "humanTransfer.keywords": {
      "label": "Transfer Keywords",
      "placeholder": "转人工,人工客服"
    }
  },
  "toolMetadata": {
    "wecom_kf_servicer_list": { "optional": true, "description": "获取微信客服接待人员列表" },
    "wecom_kf_account_list": { "optional": true, "description": "获取微信客服账号列表" },
    "wecom_kf_account_link": { "optional": true, "description": "获取微信客服账号咨询链接" },
    "wecom_kf_session_status": { "optional": true, "description": "查询客服会话状态" },
    "wecom_kf_session_transfer": { "optional": true, "description": "变更会话状态（转人工/结束等）" },
    "wecom_kf_mcp": { "optional": true, "description": "企业微信客服 MCP 工具" }
  },
  "channelConfigs": {
    "wecom-kf": {
      "label": "WeCom CS（企业微信智能客服）",
      "description": "企业微信多模态智能客服 — Bot + Agent + KF 三模式，多账户矩阵，RAG 知识库，对话状态流，ICS REST API",
      "schema": {
        "type": "object",
        "additionalProperties": true,
        "properties": {}
      }
    }
  }
}
